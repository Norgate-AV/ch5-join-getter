{
    "name": "@norgate-av/ch5-join-getter",
    "displayName": "ch5-join-getter",
    "description": "A simple package to get the most up-to-date reserved join data from the ch5 site",
    "version": "1.0.1",
    "license": "MIT",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "files": [
        "dist"
    ],
    "repository": {
        "type": "git",
        "url": ""
    },
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "commit": "git-cz",
        "clean": "rimraf dist",
        "lint": "tsc",
        "pretty:fix": "prettier --write .",
        "prebuild": "pnpm clean",
        "build": "tsup",
        "prestart": "pnpm lint && pnpm build",
        "start": "cross-env NODE_ENV=production node dist/index.js",
        "dev": "nodemon --exec vite-node src/app.ts",
        "test": "vitest --run --passWithNoTests",
        "prepare": "husky",
        "doctoc": "doctoc --title '## Contents 📖' README.md",
        "contrib:add": "all-contributors add",
        "contrib:generate": "all-contributors generate",
        "contrib:check": "all-contributors check"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/config": "^4.4.0",
        "@types/node": "^25.5.2",
        "@types/nodemon": "^3.1.1",
        "all-contributors-cli": "^6.26.1",
        "commitizen": "^4.3.0",
        "cross-env": "^10.1.0",
        "cz-conventional-changelog": "^3.3.0",
        "doctoc": "^2.2.1",
        "husky": "^9.0.10",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.0.3",
        "prettier": "^3.2.5",
        "rimraf": "^6.1.3",
        "semantic-release": "^25.0.3",
        "terser": "^5.27.0",
        "tsup": "^8.0.1",
        "type-fest": "^5.5.0",
        "typescript": "^6.0.2",
        "vite": "^6.0.0",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "axios": "^1.6.7",
        "config": "^4.4.1",
        "dotenv": "^17.4.0",
        "envalid": "^8.0.0"
    }
}
